# 后端 API 网关地址 (Gateway API)
# 本地开发可填 http://localhost:8000
# 线上部署必须配置为网关真实域名（不能填 localhost）
VITE_API_BASE_URL=
VITE_PLATFORM_APP_SLUG=platform
# 平台后台独立域名（可选），命中该域名时前端自动进入平台门户
VITE_PLATFORM_ADMIN_DOMAIN=platform-admin.example.com
# 可选：平台模式（默认 platform）
# 仅在需要时使用 auto/business；正常保持 platform
VITE_ADMIN_PORTAL_MODE=platform
