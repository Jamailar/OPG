# =============================================================================
# OPG Gateway — 环境变量模板（目标态）
# 完整清单：docs/ENVIRONMENT.md
# 精简方案：docs/ENV_STREAMLINING_PLAN.md
#
# 业务账号/密钥（支付、OAuth、AI、邮件、OSS）请在 Web 管理后台配置，
# 不要写入 .env。
# =============================================================================

# --- 生产必填（Bootstrap，不可 Web 化）---
DATABASE_URL=postgresql://user:password@localhost:5432/opg_gateway
JWT_SECRET_KEY=change-me-to-a-long-random-secret
PLATFORM_SECRETS_KEY=change-me-to-another-long-random-secret
REDIS_URL=redis://localhost:6379/0

# 迁移期兼容：旧出站代理 DB 凭据加密主密钥。新环境使用 PLATFORM_SECRETS_KEY。
# OUTBOUND_PROXY_ENCRYPTION_KEY=

NODE_ENV=development
PORT=3000

# --- 冷启动可选（可在 Web「平台设置」配好后移除）---
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# =============================================================================
# 以下区块仅用于本地开发快速起步；生产请走 Web 后台
# =============================================================================

# 数据库迁移 / 调试
# DB_AUTO_MIGRATE=true
# PRISMA_QUERY_LOG=false
# PRISMA_SCHEMA_PATH=./prisma/schema.prisma

# 租户 slug 默认值
# DEFAULT_APP_SLUG=demo
# PLATFORM_APP_SLUG=platform

# JWT 会话（也可迁入平台运行时设置）
# JWT_EXPIRES_IN=24h
# JWT_REFRESH_INACTIVITY_DAYS=30
# JWT_REFRESH_ABSOLUTE_DAYS=180

# HTTP / 日志（运维向，可保留 GitOps）
# HTTP_JSON_LIMIT=20mb
# HTTP_MEDIA_JSON_LIMIT=45mb
# GATEWAY_ACCESS_LOG=all
# GATEWAY_SLOW_REQUEST_MS=3000

# AI 网关调优（运维向，默认值通常够用）
# AI_GATEWAY_REDIS_LIMITS=0
# AI_GATEWAY_MAX_USER_CONCURRENCY=16

# 开发调试（切勿用于生产）
# API_NODE_AI_DEBUG_AUTH_ENABLED=false
# API_NODE_AI_DEBUG_AUTH_TOKEN=
# API_NODE_AI_DEBUG_AUTH_USER_ID=
# ALLOW_LOCAL_RETURN_URL=false

# ---------------------------------------------------------------------------
# DEPRECATED — 已在 Web 配置，请勿在新环境使用（Phase 1 后将移除代码读取）
# 支付 → 平台「支付方式」
# SMTP → 平台「邮件服务」
# OSS  → 平台「对象存储」
# 集成 → 平台「集成密钥 / Integration Settings」
# ALIPAY_* / WECHAT_PAY_* / API_BASE_URL / SENDER_EMAIL / ALIYUN_* /
# FEEDBACK_ADMIN_API_KEY / FEEDBACK_ADMIN_API_ACTOR_USER_ID /
# AI_VOICE_CLONE_MODEL_KEY / EMAIL_SECRET_KEY 等
# ---------------------------------------------------------------------------
